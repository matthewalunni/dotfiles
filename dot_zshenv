# Source cargo env if present
[ -r "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# Probably able to remove these in favor of a the path in zshrc
if [ -r "$HOME/.local/share/bob/env/env.sh" ]; then
  . "$HOME/.local/share/bob/env/env.sh"
fi

# User binaries
export PATH="$HOME/bin:$PATH"
export EDITOR="nvim"
export VISUAL="nvim"
