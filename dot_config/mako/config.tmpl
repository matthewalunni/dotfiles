{{- $t := index .themes .theme -}}
# Mako notification daemon config

# Appearance
font=JetBrainsMono Nerd Font 11
background-color={{ $t.bg }}
text-color={{ $t.fg }}
border-color={{ $t.border_active }}
border-size=2
border-radius=10
padding=15
margin=10

# Icons
icons=1
max-icon-size=48

# Behavior
default-timeout=5000
ignore-timeout=0

# Position (top-right corner)
anchor=top-right
width=350
height=150

# Grouping
group-by=app-name

# Urgency levels
[urgency=low]
border-color={{ $t.ignored_color }}

[urgency=normal]
border-color={{ $t.border_active }}

[urgency=high]
border-color={{ $t.red }}
default-timeout=0
