{{- $t := index .themes .theme -}}
[window]
dynamic_padding = true
opacity = 0.86
decorations = "None"

[window.padding]
x = 6
y = 6

# ---------------------------------------------
# FONT
# ---------------------------------------------
[font]
size = 12.5
builtin_box_drawing = true

[font.normal]
family = "JetBrainsMono NF"
# style  = "Regular"

[font.bold]
family = "JetBrainsMono NF"
# style = "Bold"

[font.italic]
family = "JetBrainsMono NF"
# style = "Italic"

# ---------------------------------------------
# START IN WSL (login shell)
# ---------------------------------------------
[terminal.shell]
program = "C:\\Windows\\System32\\wsl.exe"
args = ["--cd", "~"]

# ---------------------------------------------
# CURSOR & SCROLLING
# ---------------------------------------------
[cursor]
style = "Beam"

[scrolling]
history = 10000

[mouse]
hide_when_typing = true

# ---------------------------------------------
# COLORS — {{ .theme }}
# ---------------------------------------------
[colors.primary]
background = "{{ replace "#" "0x" $t.bg }}"
foreground = "{{ replace "#" "0x" $t.fg }}"

[colors.normal]
black   = "{{ replace "#" "0x" $t.black }}"
red     = "{{ replace "#" "0x" $t.red }}"
green   = "{{ replace "#" "0x" $t.green }}"
yellow  = "{{ replace "#" "0x" $t.yellow }}"
blue    = "{{ replace "#" "0x" $t.blue }}"
magenta = "{{ replace "#" "0x" $t.magenta }}"
cyan    = "{{ replace "#" "0x" $t.cyan }}"
white   = "{{ replace "#" "0x" $t.white }}"

[colors.bright]
black   = "{{ replace "#" "0x" $t.br_black }}"
red     = "{{ replace "#" "0x" $t.br_red }}"
green   = "{{ replace "#" "0x" $t.br_green }}"
yellow  = "{{ replace "#" "0x" $t.br_yellow }}"
blue    = "{{ replace "#" "0x" $t.br_blue }}"
magenta = "{{ replace "#" "0x" $t.br_magenta }}"
cyan    = "{{ replace "#" "0x" $t.br_cyan }}"
white   = "{{ replace "#" "0x" $t.br_white }}"

# ---------------------------------------------
# KEY BINDINGS
# ---------------------------------------------
[[keyboard.bindings]]
key = "V"
mods = "Control|Shift"
action = "Paste"

[[keyboard.bindings]]
key = "C"
mods = "Control|Shift"
action = "Copy"

[[keyboard.bindings]]
key = "F11"
action = "ToggleFullscreen"

[[keyboard.bindings]]
key = "+"
mods = "Control"
action = "IncreaseFontSize"

[[keyboard.bindings]]
key = "-"
mods = "Control"
action = "DecreaseFontSize"

[[keyboard.bindings]]
key = "Key0"
mods = "Control"
action = "ResetFontSize"

[terminal]
