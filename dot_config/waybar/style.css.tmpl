{{- $t := index .themes .theme -}}
* {
    border: none;
    border-radius: 0;
    font-family: "JetBrainsMono Nerd Font", "Font Awesome 6 Free";
    font-size: 11px;
    min-height: 0;
}

window#waybar {
    background: transparent;
}

tooltip {
    background: rgba({{ $t.bg_rgb }}, 0.95);
    border: 2px solid rgba({{ $t.blue_rgb }}, 0.8);
    border-radius: 8px;
    padding: 8px;
    color: {{ $t.fg }};
}

tooltip label {
    color: {{ $t.fg }};
}

/* Left modules */
#custom-launcher,
#workspaces,
#window {
    background: rgba({{ $t.bg_rgb }}, 0.9);
    margin: 0;
    padding: 2px 5px;
}

#custom-launcher {
    color: {{ $t.blue }};
    font-size: 16px;
    padding: 2px 10px;
    border-radius: 8px 0 0 8px;
    margin-right: 0;
}

#workspaces {
    padding: 0 3px;
    margin: 0;
}

#workspaces button {
    padding: 2px 6px;
    color: {{ $t.ignored_color }};
    background: transparent;
    transition: all 0.3s ease;
    min-width: 24px;
}

#workspaces button:hover {
    background: rgba({{ $t.blue_rgb }}, 0.2);
    color: {{ $t.blue }};
    box-shadow: inset 0 -2px {{ $t.blue }};
}

#workspaces button.active {
    color: {{ $t.blue }};
    background: rgba({{ $t.blue_rgb }}, 0.15);
    box-shadow: inset 0 -2px {{ $t.blue }};
}

#workspaces button.urgent {
    background: rgba({{ $t.red_rgb }}, 0.3);
    color: {{ $t.red }};
}

#window {
    color: {{ $t.fg }};
    font-weight: 500;
    border-radius: 0 8px 8px 0;
    margin-left: 0;
    padding: 2px 12px;
}

/* Center module */
#clock {
    background: rgba({{ $t.bg_rgb }}, 0.9);
    color: {{ $t.blue }};
    font-weight: bold;
    font-size: 11px;
    padding: 2px 16px;
    border-radius: 8px;
}

/* Right modules */
#custom-updates,
#pulseaudio,
#network,
#cpu,
#memory,
#battery,
#tray {
    background: rgba({{ $t.bg_rgb }}, 0.9);
    padding: 2px 8px;
    margin: 0;
}

#pulseaudio {
    border-radius: 8px 0 0 8px;
    color: {{ $t.br_cyan }};
    margin: 0;
}

#pulseaudio.muted {
    color: {{ $t.ignored_color }};
}

#network {
    color: {{ $t.cyan }};
    margin: 0;
}

#network.disconnected {
    color: {{ $t.red }};
}

#cpu {
    color: {{ $t.magenta }};
    margin: 0;
}

#memory {
    color: {{ $t.yellow }};
    margin: 0;
}

#battery {
    color: {{ $t.br_green }};
    margin: 0;
    border-radius: 0 8px 8px 0;
}

#battery.charging, #battery.plugged {
    color: {{ $t.br_green }};
}

#battery.good {
    color: {{ $t.br_green }};
}

#battery.warning:not(.charging) {
    color: {{ $t.br_yellow }};
}

#battery.critical:not(.charging) {
    color: {{ $t.red }};
    animation-name: blink;
    animation-duration: 0.5s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-direction: alternate;
}

@keyframes blink {
    to {
        background-color: rgba({{ $t.red_rgb }}, 0.3);
    }
}

#tray {
    padding: 2px 0px;
    margin: 0;
}

#tray > .passive {
    -gtk-icon-effect: dim;
}

#tray > .needs-attention {
    -gtk-icon-effect: highlight;
    background-color: {{ $t.red }};
}

/* Hover effects */
#custom-launcher:hover,
#custom-updates:hover,
#pulseaudio:hover,
#network:hover,
#cpu:hover,
#memory:hover,
#battery:hover {
    background: rgba({{ $t.surface_rgb }}, 0.95);
    transition: all 0.3s ease;
}

#clock:hover {
    background: rgba({{ $t.surface_rgb }}, 0.95);
    color: {{ $t.magenta }};
    transition: all 0.3s ease;
}
